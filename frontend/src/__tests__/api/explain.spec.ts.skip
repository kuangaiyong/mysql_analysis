import { describe, it, expect, vi, beforeEach, afterEach } from "vitest"

vi.mock("@/api/client", () => ({
  default: {
    get: vi.fn(),
    post: vi.fn(),
    put: vi.fn(),
    delete: vi.fn()
  }
}))

import { explainApi } from "@/api/explain"
import service from "@/api/client"

describe("explain API", () => {
  beforeEach(() => {
    vi.clearAllMocks()
  })

  afterEach(() => {
    vi.restoreAllMocks()
  })

  describe("explain", () => {
    it("should return explain results", async () => {
      const mockRows: any[] = [
        { id: 1, select_type: "SIMPLE", table: "users", type: "ALL" }
      ]
      const mockData = { type: "traditional", query: "SELECT * FROM users", rows: mockRows }
      ;(service.post as any).mockResolvedValue({ data: mockData })

      const result = await explainApi.explain(1, { sql: "SELECT * FROM users", analyze_type: "traditional" })

      expect(service.post).toHaveBeenCalledWith("/explain/analyze?connection_id=1", {
        sql: "SELECT * FROM users",
        analyze_type: "traditional",
        database_name: undefined
      })
      expect(result).toEqual(mockRows)
    })

    it("should return empty array when no rows in response", async () => {
      ;(service.post as any).mockResolvedValue({ data: { type: "traditional", query: "SELECT 1" } })

      const result = await explainApi.explain(1, { sql: "SELECT 1", analyze_type: "traditional" })

      expect(result).toEqual([])
    })

    it("should handle API error", async () => {
      ;(service.post as any).mockRejectedValue(new Error("Explain failed"))

      await expect(explainApi.explain(1, { sql: "SELECT 1", analyze_type: "traditional" })).rejects.toThrow("Explain failed")
    })
  })

  describe("analyzeExecution", () => {
    it("should return execution analysis results", async () => {
      const mockRows: any[] = [
        { id: 1, select_type: "SIMPLE", table: "orders", type: "ref" }
      ]
      const mockData = { rows: mockRows }
      ;(service.post as any).mockResolvedValue({ data: mockData })

      const result = await explainApi.analyzeExecution(1, "SELECT * FROM orders WHERE id = 1", "mydb")

      expect(service.post).toHaveBeenCalledWith("/explain/analyze-execution?connection_id=1", {
        sql: "SELECT * FROM orders WHERE id = 1",
        database_name: "mydb"
      })
      expect(result).toEqual(mockRows)
    })

    it("should handle API error", async () => {
      ;(service.post as any).mockRejectedValue(new Error("Analysis failed"))

      await expect(explainApi.analyzeExecution(1, "SELECT 1")).rejects.toThrow("Analysis failed")
    })
  })

  describe("getIndexSuggestions", () => {
    it("should return index suggestions", async () => {
      const mockSuggestions = {
        suggestions: [
          { type: "index", table: "users", columns: ["id"], reason: "Primary key" }
        ]
      }
      ;(service.post as any).mockResolvedValue({ data: mockSuggestions })

      const result = await explainApi.getIndexSuggestions(1, "SELECT * FROM users WHERE id = 1", "users")

      expect(service.post).toHaveBeenCalledWith("/explain/index-suggestions?connection_id=1", {
        sql: "SELECT * FROM users WHERE id = 1",
        table_name: "users"
      })
      expect(result).toEqual(mockSuggestions)
    })

    it("should handle API error", async () => {
      ;(service.post as any).mockRejectedValue(new Error("Failed to get suggestions"))

      await expect(explainApi.getIndexSuggestions(1, "SELECT 1")).rejects.toThrow("Failed to get suggestions")
    })
  })
})
