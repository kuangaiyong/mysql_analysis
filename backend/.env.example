# ==================== 应用配置 ====================
APP_NAME=MySQL性能诊断系统
APP_VERSION=1.0.0
DEBUG=True

# ==================== 数据库配置 ====================
# 系统自己的数据库（存储配置、指标、分析结果等）
DATABASE_URL=mysql+pymysql://YOUR_USERNAME:YOUR_PASSWORD@YOUR_HOST:3306/YOUR_DATABASE

# ==================== 目标MySQL数据库配置（被监控的数据库）====================
TARGET_MYSQL_HOST=localhost
TARGET_MYSQL_PORT=3306
TARGET_MYSQL_USER=YOUR_USERNAME
TARGET_MYSQL_PASSWORD=YOUR_PASSWORD
TARGET_MYSQL_DATABASE=YOUR_DATABASE

# ==================== Redis配置 ====================
REDIS_URL=localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_CACHE_TTL=3600

# ==================== CORS配置 ====================
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# ==================== JWT配置 ====================
# 请使用以下命令生成安全的密钥：
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Celery配置 ====================
CELERY_BROKER_URL=redis://YOUR_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://YOUR_REDIS_PASSWORD@localhost:6379/2

# ==================== 性能采集配置 ====================
METRICS_COLLECTION_INTERVAL=60
SLOW_QUERY_THRESHOLD=1.0
SLOW_QUERY_LOG_PATH=/var/log/mysql/slow-query.log

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== AI 配置 ====================
AI_ENABLED=True
AI_PROVIDER=zhipu

# Kimi AI
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding

# 智谱 AI GLM
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_MODEL=GLM-5

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
